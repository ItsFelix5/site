<pre id="rat"></pre>
<div id="hefuckingdied">
  <p>You killed him :(</p>
</div>

<script>
  import { vertices as localVerts, faces } from "../lib/rat.json";
  import squeakUrl from "../assets/squeak.mp3";
  import explosionUrl from "../assets/explosion.mp3";

  const CHARS =
    " .'`^\",:;Il!i><~+_-?][}{1)(\\/tfjrxnuvczXYUJCLQ0OZmwqpdbkhao*#MW&8%B@$";

  function buildCircleMasks(resX: number, resY: number) {
    const masks: [number, number][][] = [];
    for (const cyP of [1 / 3, 1, 5 / 3]) {
      for (const cxP of [0.25, 0.75]) {
        const offsets: [number, number][] = [];
        const rx = Math.ceil(0.3 * resX) + 1;
        const ry = Math.ceil((0.3 / 2) * resY) + 1;
        const baseDx = Math.round(cxP * resX);
        const baseDy = Math.round((cyP / 2) * resY);
        for (let dy = baseDy - ry; dy <= baseDy + ry; dy++) {
          for (let dx = baseDx - rx; dx <= baseDx + rx; dx++) {
            const ddx = (dx + 0.5) / resX - cxP;
            const ddy = ((dy + 0.5) * 2) / resY - cyP;
            if (ddx * ddx + ddy * ddy <= 0.09) offsets.push([dx, dy]);
          }
        }
        masks.push(offsets);
      }
    }
    return masks;
  }

  const charVectors = (() => {
    const canvas = document.createElement("canvas");
    canvas.width = 32;
    canvas.height = 64;
    const ctx = canvas.getContext("2d", { willReadFrequently: true })!;
    ctx.textAlign = "center";
    ctx.textBaseline = "middle";
    ctx.font = `64px monospace`;

    const glyphMasks = buildCircleMasks(32, 64);
    return CHARS.split("").map((ch) => {
      ctx.fillStyle = "#000";
      ctx.fillRect(0, 0, 32, 64);
      ctx.fillStyle = "#fff";
      ctx.fillText(ch, 16, 33);
      const { data } = ctx.getImageData(0, 0, 32, 64);

      return new Float32Array(6).map((_, m) => {
        const offsets = glyphMasks[m].filter(
          ([dx, dy]) => dx >= 0 && dx < 32 && dy >= 0 && dy < 64,
        );
        return (
          offsets.reduce(
            (a, [dx, dy]) => a + data[(dy * 32 + dx) * 4] / 255,
            0,
          ) / offsets.length || 0
        );
      });
    });
  })();

  const matchCache = new Map<number, number>();

  const cellMasks = buildCircleMasks(6, 12);

  const faceNormalX = new Float64Array(faces.length / 3);
  const faceNormalY = new Float64Array(faces.length / 3);
  const faceNormalZ = new Float64Array(faces.length / 3);
  for (let f = 0; f < faces.length / 3; f++) {
    const a = faces[f * 3],
      b = faces[f * 3 + 1],
      c = faces[f * 3 + 2];
    const ax = localVerts[a * 3],
      ay = localVerts[a * 3 + 1],
      az = localVerts[a * 3 + 2];
    const bx = localVerts[b * 3],
      by = localVerts[b * 3 + 1],
      bz = localVerts[b * 3 + 2];
    const cx = localVerts[c * 3],
      cy = localVerts[c * 3 + 1],
      cz = localVerts[c * 3 + 2];
    faceNormalX[f] = (by - ay) * (cz - az) - (bz - az) * (cy - ay);
    faceNormalY[f] = (bz - az) * (cx - ax) - (bx - ax) * (cz - az);
    faceNormalZ[f] = (bx - ax) * (cy - ay) - (by - ay) * (cx - ax);
  }

  let scale = 1;
  let scaleVelocity = 0;
  let angle = 0;
  let clicks = Math.floor(Math.random() * 10) + 5;

  const squeakAudio = new Audio(squeakUrl);
  const explosionAudio = new Audio(explosionUrl);

  let explosionStart = 0;
  let particles: {
    angle: number;
    speed: number;
    vy0: number;
    radius: number;
    lifetime: number;
    heat: number;
  }[] = [];

  const FIRE_STOPS: [number, number, number, number][] = [
    [0, 10, 10, 10],
    [0.15, 60, 20, 10],
    [0.3, 140, 30, 0],
    [0.45, 200, 60, 0],
    [0.6, 255, 110, 0],
    [0.75, 255, 170, 30],
    [0.9, 255, 215, 110],
    [1.15, 255, 255, 245],
  ];

  function renderExplosion(t: number) {
    const cols = 120;
    const rows = 48;
    const cx = 60;
    const cy = 24;
    const heatGrid = new Float32Array(cols * rows);

    for (const p of particles) {
      const life = t / p.lifetime;
      if (life >= 1) {
        particles = particles.filter((x) => x !== p);
        continue;
      }
      const px = cx + Math.cos(p.angle) * (p.speed * t * 1 - 0.35 * life);
      const py = cy + p.vy0 * t + 0.5 * 10 * t * t;
      const sigma = p.radius * (0.5 + life * 1.2);
      const heatAmt = p.heat * (1 - life * life);

      const reach = sigma * 2.2;
      for (
        let row = Math.max(0, Math.floor(py - reach));
        row <= Math.min(rows - 1, Math.ceil(py + reach));
        row++
      ) {
        const dy = (row - py) * 2;
        for (
          let col = Math.max(0, Math.floor(px - reach));
          col <= Math.min(cols - 1, Math.ceil(px + reach));
          col++
        ) {
          const dx = col - px;
          const v =
            heatAmt * Math.exp(-(dx * dx + dy * dy) / (2 * sigma * sigma));
          if (v > heatGrid[row * cols + col]) heatGrid[row * cols + col] = v;
        }
      }
    }

    const flash = Math.max(0, 1 - t / 0.2) * 1.2;
    let html = "";
    for (let row = 0; row < rows; row++) {
      let rowHtml = "";
      let curColor = "";
      let buf = "";
      for (let col = 0; col < cols; col++) {
        const fdx = col - cx;
        const fdy = (row - cy) * 2;
        let h =
          heatGrid[row * cols + col] +
          flash * Math.exp(-(fdx * fdx + fdy * fdy) / 450);
        h += (Math.random() - 0.5) * 0.06 * Math.min(1, h + 0.2);
        const clamped = Math.max(0, Math.min(1.15, h));

        let lo = FIRE_STOPS[0];
        let hi = FIRE_STOPS[FIRE_STOPS.length - 1];
        for (let i = 0; i < FIRE_STOPS.length - 1; i++) {
          if (clamped >= FIRE_STOPS[i][0] && clamped <= FIRE_STOPS[i + 1][0]) {
            lo = FIRE_STOPS[i];
            hi = FIRE_STOPS[i + 1];
            break;
          }
        }
        const f = (clamped - lo[0]) / (hi[0] - lo[0] || 1);
        const color = `rgb(${Math.round(lo[1] + (hi[1] - lo[1]) * f)},${Math.round(lo[2] + (hi[2] - lo[2]) * f)},${Math.round(lo[3] + (hi[3] - lo[3]) * f)})`;
        if (color !== curColor) {
          if (buf) rowHtml += `<span style="color:${curColor}">${buf}</span>`;
          curColor = color;
          buf = "";
        }
        buf += " .:-=+*#%@"[Math.round((clamped / 1.15) * 9)];
      }
      if (buf) rowHtml += `<span style="color:${curColor}">${buf}</span>`;
      html += rowHtml + "\n";
    }
    document.getElementById("rat")!.innerHTML = `<span>${html}</span>`;
  }

  function render() {
    const subScale = scale * 0.7256773581549772;
    const cosYaw = Math.cos(angle);
    const sinYaw = Math.sin(angle);

    const litBuf = new Float32Array(720 * 576);
    const depthBuf = new Float64Array(720 * 576).fill(-Infinity);
    const viewZ = new Float64Array(localVerts.length / 3);
    const screenX = new Float64Array(localVerts.length / 3);
    const screenY = new Float64Array(localVerts.length / 3);

    for (let j = 0; j < localVerts.length / 3; j++) {
      const x = localVerts[j * 3];
      const y = localVerts[j * 3 + 1];
      const z = localVerts[j * 3 + 2];
      const rx = x * cosYaw + z * sinYaw;
      const rz = z * cosYaw - x * sinYaw;
      viewZ[j] = rz;
      screenX[j] = rx * subScale + 360;
      screenY[j] = 288 - y * subScale;
    }

    for (let f = 0; f < faces.length / 3; f++) {
      const a = faces[f * 3],
        b = faces[f * 3 + 1],
        c = faces[f * 3 + 2];

      let litNormalX = faceNormalX[f] * cosYaw + faceNormalZ[f] * sinYaw;
      let litNormalY = faceNormalY[f];
      let litNormalZ = faceNormalZ[f] * cosYaw - faceNormalX[f] * sinYaw;
      if (litNormalZ < 0) {
        litNormalX = -litNormalX;
        litNormalY = -litNormalY;
        litNormalZ = -litNormalZ;
      }

      const ax = screenX[a],
        ay = screenY[a];
      const bx = screenX[b],
        by = screenY[b];
      const cx = screenX[c],
        cy = screenY[c];

      const area = (bx - ax) * (cy - ay) - (cx - ax) * (by - ay);
      if (Math.abs(area) < 1e-6) continue;

      const az = viewZ[a],
        bz = viewZ[b],
        cz = viewZ[c];
      const edgeNx = [-(by - ay), -(cy - by), -(ay - cy)];
      const edgeNy = [bx - ax, cx - bx, ax - cx];
      const edgeMin = [0, 0, 0];
      const edgeMax = [0, 0, 0];
      for (let e = 0; e < 3; e++) {
        const d0 = edgeNx[e] * ax + edgeNy[e] * ay;
        const d1 = edgeNx[e] * bx + edgeNy[e] * by;
        const d2 = edgeNx[e] * cx + edgeNy[e] * cy;
        edgeMin[e] = Math.min(d0, d1, d2);
        edgeMax[e] = Math.max(d0, d1, d2);
      }

      for (
        let row = Math.max(0, Math.floor(Math.min(ay, by, cy)));
        row <= Math.min(575, Math.ceil(Math.max(ay, by, cy)));
        row++
      ) {
        for (
          let col = Math.max(0, Math.floor(Math.min(ax, bx, cx)));
          col <= Math.min(719, Math.ceil(Math.max(ax, bx, cx)));
          col++
        ) {
          let overlaps = true;
          for (let e = 0; e < 3; e++) {
            if (
              edgeMax[e] <
                edgeNx[e] * (edgeNx[e] >= 0 ? col : col + 1) +
                  edgeNy[e] * (edgeNy[e] >= 0 ? row : row + 1) ||
              edgeMin[e] >
                edgeNx[e] * (edgeNx[e] >= 0 ? col + 1 : col) +
                  edgeNy[e] * (edgeNy[e] >= 0 ? row + 1 : row)
            ) {
              overlaps = false;
              break;
            }
          }
          if (!overlaps) continue;

          const cpx = col + 0.5,
            cpy = row + 0.5;
          const w0 = ((bx - cpx) * (cy - cpy) - (cx - cpx) * (by - cpy)) / area;
          const w1 = ((cx - cpx) * (ay - cpy) - (ax - cpx) * (cy - cpy)) / area;
          const depth = w0 * az + w1 * bz + (1 - w0 - w1) * cz;
          const p = row * 720 + col;
          if (depth > depthBuf[p]) {
            depthBuf[p] = depth;
            litBuf[p] = Math.min(
              1,
              0.18 +
                0.82 *
                  Math.max(
                    0,
                    (litNormalX * -0.4 + litNormalY * 0.55 + litNormalZ * 0.8) /
                      (Math.hypot(
                        faceNormalX[f],
                        faceNormalY[f],
                        faceNormalZ[f],
                      ) || 1),
                  ),
            );
          }
        }
      }
    }

    let ascii = "";
    for (let row = 0; row < 48; row++) {
      for (let col = 0; col < 120; col++) {
        const shapeVec = new Array(6);
        for (let m = 0; m < 6; m++) {
          const offsets = cellMasks[m];
          let sum = 0;
          let count = 0;
          for (const [dx, dy] of offsets) {
            const gx = col * 6 + dx;
            const gy = row * 12 + dy;
            if (gx < 0 || gx >= 720 || gy < 0 || gy >= 576) continue;
            sum += litBuf[gy * 720 + gx];
            count++;
          }
          shapeVec[m] = count > 0 ? sum / count : 0;
        }

        let max = 0;
        for (const v of shapeVec) if (v > max) max = v;
        if (max >= 1e-4)
          for (let k = 0; k < shapeVec.length; k++)
            shapeVec[k] = Math.pow(shapeVec[k] / max, 2.5) * max;

        let key = 0;
        for (let k = 0; k < 6; k++)
          key =
            (key << 4) |
            Math.min(15, Math.max(0, Math.round(shapeVec[k] * 15)));
        let bestIdx = matchCache.get(key >>> 0);
        if (bestIdx == undefined) {
          let bestDist = Infinity;
          for (let i = 0; i < charVectors.length; i++) {
            let d = 0;
            for (let k = 0; k < 6; k++) {
              const diff = shapeVec[k] - charVectors[i][k];
              d += diff * diff;
            }
            if (d < bestDist) {
              bestDist = d;
              bestIdx = i;
            }
          }
          matchCache.set(key >>> 0, bestIdx!);
        }

        ascii += CHARS[bestIdx!];
      }
      ascii += "\n";
    }
    document.getElementById("rat")!.textContent = ascii;
  }

  let last = 0;
  let lastPhysics = 0;
  function frame(now: number) {
    if (explosionStart) {
      if (particles.length) {
        const t = (now - explosionStart) / 1500;
        renderExplosion(t);
        requestAnimationFrame(frame);
      } else document.getElementById("hefuckingdied")!.style.opacity = "1";
      return;
    }

    if (Math.abs(scale - 1) > 1e-4 || Math.abs(scaleVelocity) > 1e-4) {
      const dt = Math.min(0.05, (now - lastPhysics) / 1000);
      lastPhysics = now;
      scaleVelocity += (-75 * (scale - 1) - 9 * scaleVelocity) * dt;
      scale += scaleVelocity * dt;
    }

    if (now - last > 50) {
      angle += 0.05;
      if (scale > 0) render();
      last = now;
    }
    requestAnimationFrame(frame);
  }
  requestAnimationFrame(frame);

  document.getElementById("rat")!.addEventListener("click", () => {
    if (explosionStart) return;

    const now = performance.now();
    squeakAudio.currentTime = 0;
    squeakAudio.play().catch(() => {});
    scaleVelocity -= 6;

    if (--clicks <= 0) {
      explosionStart = now;
      particles = Array.from({ length: 100 }, () => {
        const angle = Math.random() * Math.PI * 2;
        const speed = 5 + Math.random() * 23;
        return {
          angle,
          speed,
          vy0: Math.sin(angle) * speed * 0.5 - Math.random() * 4,
          radius: 2 + Math.random() * 2.5,
          lifetime: 1.1 + Math.random() * 1.1,
          heat: 0.85 + Math.random() * 0.3,
        };
      });
      explosionAudio.currentTime = 0;
      explosionAudio.play().catch(() => {});
    }
  });
</script>

<style>
  #rat {
    font-family: monospace;
    font-size: clamp(6px, 1.6vw, 13px);
    line-height: 1;
    letter-spacing: 0;
    color: #ffffff;
    background: #05070a;
    margin: 0;
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    white-space: pre;
    user-select: none;
  }

  #hefuckingdied {
    font-family: sans-serif;
    position: fixed;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    color: #ffffff;
    opacity: 0;
    pointer-events: none;
    transition: opacity 8s ease-in;
  }
</style>
